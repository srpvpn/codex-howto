{
  "description": "Example Codex configuration profiles expressed as TOML snippets inside JSON for reference.",
  "examples": {
    "development": {
      "name": "Development",
      "toml": "model = \"gpt-5.4\"\nmodel_reasoning_effort = \"medium\"\nsandbox_mode = \"workspace-write\"\n\n[sandbox_workspace_write]\nnetwork_access = false\n"
    },
    "code_review": {
      "name": "Code Review",
      "toml": "model = \"gpt-5.4\"\nmodel_reasoning_effort = \"high\"\nsandbox_mode = \"read-only\"\napproval_policy = \"on-request\"\n"
    },
    "research_with_search": {
      "name": "Research with Web Search",
      "toml": "model = \"gpt-5.4\"\nsandbox_mode = \"workspace-write\"\n\n[sandbox_workspace_write]\nnetwork_access = true\n"
    },
    "local_automation": {
      "name": "Local Automation",
      "toml": "model = \"gpt-5.4\"\nsandbox_mode = \"workspace-write\"\napproval_policy = \"never\"\nnotify = [\"/usr/local/bin/codex-notify\"]\n"
    }
  }
}
